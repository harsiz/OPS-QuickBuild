#  в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ    в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—
#  в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—    в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘
#  в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘    в–Ҳв–Ҳв•‘в–„в–„ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘
#  в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘    в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ
#   в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ     в•ҡв•җв•җв•җв•җв•җв•җв•қ     в•ҡв•җв•җв–Җв–Җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•җв•җв•җв•җв•қ
#
#  OPS_QuickBuild вҖ” builds an entire osu! private server (osu!stable, -devserver) in one go рҹҳҺ
#  target: Debian / Ubuntu servers. stack: bancho.py + MariaDB + Redis + nginx.
#
set -euo pipefail

OPS_VERSION="1.0.0"
BANCHO_REPO="https://github.com/osuAkatsuki/bancho.py.git"
OPS_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# в”Җв”Җв”Җ colors в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
R=$'\033[0m'; B=$'\033[1m'; DIM=$'\033[2m'
RED=$'\033[31m'; GRN=$'\033[32m'; YLW=$'\033[33m'; BLU=$'\033[34m'
MAG=$'\033[35m'; CYN=$'\033[36m'; PNK=$'\033[95m'

ok()   { echo -e "  ${GRN}вң… $*${R}"; }
info() { echo -e "  ${CYN}рҹ”№ $*${R}"; }
warn() { echo -e "  ${YLW}вҡ пёҸ  $*${R}"; }
die()  { echo -e "\n  ${RED}${B}рҹ’Җ nah that ain't it: $*${R}\n" >&2; exit 1; }
step() { STEP_N=$((STEP_N+1)); echo -e "\n${MAG}${B}в”Җв”Җ [$STEP_N/$STEP_TOTAL] $* в”Җв”Җ${R}"; }
STEP_N=0; STEP_TOTAL=12

ask() { # ask "prompt" "default" -> REPLY_VAL
  local prompt="$1" def="${2-}"
  if [[ -n "$def" ]]; then
    read -r -p "  ${CYN}вқ“ ${prompt} ${DIM}[${def}]${R}: " REPLY_VAL </dev/tty || true
    REPLY_VAL="${REPLY_VAL:-$def}"
  else
    while true; do
      read -r -p "  ${CYN}вқ“ ${prompt}${R}: " REPLY_VAL </dev/tty || true
      [[ -n "$REPLY_VAL" ]] && break
      echo -e "  ${YLW}bro you gotta type something рҹҳӯ${R}"
    done
  fi
}

banner() {
  echo -e "${PNK}${B}"
  cat <<'EOF'

   в•”в•җв•—в•”в•җв•—в•”в•җв•—   в•”в•җв•— в”¬ в”¬в”¬в”Ңв”Җв”җв”¬в”Ңв”Җв•”в•— в”¬ в”¬в”¬в”¬  в•”в•Ұв•—
   в•‘ в•‘в• в•җв•қв•ҡв•җв•—   в•‘в•җв•¬в•—в”Ӯ в”Ӯв”Ӯв”Ӯ  в”ңв”ҙв”җв• в•©в•—в”Ӯ в”Ӯв”Ӯв”Ӯ   в•‘в•‘
   в•ҡв•җв•қв•©  в•ҡв•җв•қ   в•ҡв•җв•қв•ҡв””в”Җв”ҳв”ҙв””в”Җв”ҳв”ҙ в”ҙв•ҡв•җв•қв””в”Җв”ҳв”ҙв”ҙв”Җв”ҳв•җв•©в•қ
EOF
  echo -e "${R}${DIM}   osu! private server, built for you, start to finish рҹҳҺ  v${OPS_VERSION}${R}"
  echo -e "${DIM}   stack: bancho.py вҖў MariaDB вҖў Redis вҖў nginx вҖў osu!stable (-devserver)${R}\n"
}

# в”Җв”Җв”Җ preflight в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
banner

[[ "$(id -u)" -eq 0 ]] || die "run me as root bestie (sudo ./ops-quickbuild)"
command -v apt-get >/dev/null 2>&1 || die "no apt?? this tool is for Debian/Ubuntu servers only"
info "root check passed, apt found вҖ” we ball рҹӨқ"

# в”Җв”Җв”Җ gather config в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo -e "\n${B}${PNK}рҹ“қ ok first, tell me about your server${R}\n"

ask "server name (the vibe, e.g. 'Ouendan')" "MyOsuServer";           SERVER_NAME="$REPLY_VAL"
SLUG="$(echo "$SERVER_NAME" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/^-*//;s/-*$//')"
[[ -n "$SLUG" ]] || SLUG="osu-server"

ask "domain (players connect with osu!.exe -devserver <this>)" "";    DOMAIN="$REPLY_VAL"
[[ "$DOMAIN" == *.* ]] || die "'$DOMAIN' is not a real domain lol, needs a dot (e.g. cool-server.xyz)"

ask "bot name (chat bot, user id 1)" "${SERVER_NAME}Bot";             BOT_NAME="$REPLY_VAL"
ask "install directory" "/opt/${SLUG}";                               INSTALL_DIR="$REPLY_VAL"
ask "app port (internal, nginx proxies to it)" "10000";               APP_PORT="$REPLY_VAL"
ask "path to your accounts file (username:password per line, blank = skip)" "-"; ACCOUNTS_FILE="$REPLY_VAL"
[[ "$ACCOUNTS_FILE" == "-" ]] && ACCOUNTS_FILE=""
if [[ -n "$ACCOUNTS_FILE" && ! -f "$ACCOUNTS_FILE" ]]; then
  die "accounts file '$ACCOUNTS_FILE' doesn't exist рҹ’Җ (make it or pass '-' to skip)"
fi
# resolve to absolute path NOW вҖ” the installer cd's around later
[[ -n "$ACCOUNTS_FILE" ]] && ACCOUNTS_FILE="$(readlink -f "$ACCOUNTS_FILE")"
ask "osu! api v1 key (optional, helps with beatmap lookups вҖ” blank is fine)" "-"; OSU_API_KEY="$REPLY_VAL"
[[ "$OSU_API_KEY" == "-" ]] && OSU_API_KEY=""

echo -e "\n  ${B}рҹ”җ SSL вҖ” osu!stable REQUIRES https on all subdomains:${R}"
echo -e "     ${GRN}1)${R} Let's Encrypt wildcard cert (real domain, you'll add a DNS TXT record вҖ” recommended)"
echo -e "     ${YLW}2)${R} self-signed cert (testing only вҖ” every player must install it as trusted root)"
echo -e "     ${DIM}3)${R} skip (you already have certs, you'll wire them up yourself)"
ask "pick 1/2/3" "1"; SSL_MODE="$REPLY_VAL"

DB_NAME="${SLUG//-/_}"
DB_USER="${DB_NAME:0:16}"
DB_PASS="$(openssl rand -hex 16 2>/dev/null || head -c16 /dev/urandom | od -An -tx1 | tr -d ' \n')"

echo -e "\n${B}${PNK}рҹ§ҫ the plan:${R}"
echo -e "   ${DIM}server${R}    ${B}$SERVER_NAME${R} ($SLUG)"
echo -e "   ${DIM}domain${R}    ${B}$DOMAIN${R} (+ osu. c. ce. c4. c5. c6. a. b. api. assets. subdomains)"
echo -e "   ${DIM}install${R}   $INSTALL_DIR"
echo -e "   ${DIM}database${R}  $DB_NAME (user: $DB_USER, password: auto-generated рҹ”’)"
echo -e "   ${DIM}accounts${R}  ${ACCOUNTS_FILE:-"(none вҖ” import later with import-accounts.sh)"}"
echo -e "   ${DIM}ssl${R}       mode $SSL_MODE"
ask "we doing this? (yes/no)" "yes"
[[ "$REPLY_VAL" =~ ^[Yy] ]] || die "aight, cancelled. run me again when you're ready рҹ«Ў"

BANCHO_DIR="$INSTALL_DIR/bancho.py"
OPS_DIR="$INSTALL_DIR/ops"
CERT_DIR="$INSTALL_DIR/certs"
DATA_DIR="$BANCHO_DIR/.data"
REPORT="$INSTALL_DIR/ops-quickbuild-report.txt"

# в”Җв”Җв”Җ 1. system packages в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
step "рҹ“Ұ installing system packages (this is the boring part, hang tight)"
export DEBIAN_FRONTEND=noninteractive
apt-get update -qq
apt-get install -y -qq git curl ca-certificates build-essential \
  nginx mariadb-server redis-server certbot tmux openssl dnsutils >/dev/null
ok "git, nginx, mariadb, redis, certbot, tmux вҖ” all installed"

systemctl enable --now mariadb redis-server nginx >/dev/null 2>&1
ok "mariadb + redis + nginx are up and enabled on boot"

# в”Җв”Җв”Җ 2. uv + rust toolchain в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
step "рҹҗҚ installing uv + rust (rust compiles the pp calculator рҹҰҖ)"
if ! command -v uv >/dev/null 2>&1; then
  curl -LsSf https://astral.sh/uv/install.sh | sh >/dev/null 2>&1
  export PATH="$HOME/.local/bin:$PATH"
fi
command -v uv >/dev/null 2>&1 || die "uv didn't install, check your network"
ok "uv ready: $(uv --version)"

# akatsuki-pp-py (bancho's pp calculator) often has no prebuilt wheel and
# must be compiled from rust source вҖ” that needs cargo in PATH.
if ! command -v cargo >/dev/null 2>&1; then
  info "no cargo found вҖ” grabbing rust via rustup (one-time, takes a min)"
  curl -sSf https://sh.rustup.rs | sh -s -- -y --profile minimal --default-toolchain stable >/dev/null 2>&1 \
    || die "rustup install failed вҖ” check network, then rerun me"
fi
[[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"
export PATH="$HOME/.cargo/bin:$PATH"
command -v cargo >/dev/null 2>&1 || die "cargo still not in PATH after rustup?? run: source ~/.cargo/env, then rerun me"
ok "rust ready: $(cargo --version | awk '{print $1, $2}')"

# в”Җв”Җв”Җ 3. clone bancho.py в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
step "в¬ҮпёҸ  pulling bancho.py (the actual server software)"
mkdir -p "$INSTALL_DIR" "$OPS_DIR" "$CERT_DIR"
if [[ -d "$BANCHO_DIR/.git" ]]; then
  warn "bancho.py already cloned at $BANCHO_DIR вҖ” reusing it"
else
  git clone --depth 1 "$BANCHO_REPO" "$BANCHO_DIR" 2>&1 | tail -1
fi
ok "bancho.py source in place"

# в”Җв”Җв”Җ 4. python deps в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
step "рҹ§Ә installing python dependencies (uv sync вҖ” grabs the pp calculator too)"
cd "$BANCHO_DIR"
info "if the pp calculator compiles from source this can take a few mins вҖ” it's not stuck, rust is just cooking рҹҰҖ"
uv sync --no-install-project >/dev/null 2>&1 || uv sync --no-install-project || uv sync
uv pip install --python "$BANCHO_DIR/.venv/bin/python" pymysql >/dev/null
VENV_PY="$BANCHO_DIR/.venv/bin/python"
ok "venv built, deps locked, pymysql added for the ops scripts"

# в”Җв”Җв”Җ 5. database в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
step "рҹ—„пёҸ  creating the database (users, scores, maps, stats вҖ” the whole schema)"
mysql -u root <<SQL
CREATE DATABASE IF NOT EXISTS \`$DB_NAME\` CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci;
CREATE USER IF NOT EXISTS '$DB_USER'@'localhost' IDENTIFIED BY '$DB_PASS';
ALTER USER '$DB_USER'@'localhost' IDENTIFIED BY '$DB_PASS';
GRANT ALL PRIVILEGES ON \`$DB_NAME\`.* TO '$DB_USER'@'localhost';
FLUSH PRIVILEGES;
SQL
if ! mysql -u root "$DB_NAME" -e "SELECT 1 FROM users LIMIT 1" >/dev/null 2>&1; then
  mysql -u root "$DB_NAME" < "$BANCHO_DIR/migrations/base.sql"
  ok "schema imported from migrations/base.sql"
else
  warn "schema already exists вҖ” leaving your data alone"
fi
BOT_SAFE="$(echo "$BOT_NAME" | tr '[:upper:]' '[:lower:]' | tr ' ' '_')"
mysql -u root "$DB_NAME" -e "UPDATE users SET name='$BOT_NAME', safe_name='$BOT_SAFE' WHERE id=1;" || true
ok "bot renamed to '$BOT_NAME' (they live in every chat now рҹҳҺ)"

# в”Җв”Җв”Җ 6. geo database (player flags) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
step "рҹҢҚ grabbing GeoLite2 db (so player flags actually work)"
mkdir -p "$DATA_DIR"
MMDB="$DATA_DIR/GeoLite2-City.mmdb"
if [[ ! -f "$MMDB" ]]; then
  if curl -fsSL -o "$MMDB" "https://github.com/P3TERX/GeoLite.mmdb/raw/download/GeoLite2-City.mmdb"; then
    ok "GeoLite2-City.mmdb downloaded"
  else
    warn "couldn't download GeoLite2 вҖ” flags may be wrong, not fatal. drop one at $MMDB later"
  fi
else
  ok "GeoLite2 already present"
fi

# в”Җв”Җв”Җ 7. ssl certs в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
step "рҹ”җ sorting out SSL"
CERT_PATH=""; KEY_PATH=""
case "$SSL_MODE" in
  1)
    echo -e "  ${B}certbot is about to ask you to create TWO DNS TXT records${R} (one for the"
    echo -e "  ${B}domain, one for the wildcard вҖ” SAME name, different values).${R}"
    echo -e "  ${DIM}вҖў add the first TXT record it shows, press enter, it shows a SECOND one"
    echo -e "  вҖў add that too вҖ” BOTH records must exist at the same time, don't delete the first!"
    echo -e "  вҖў before the final enter, verify with:  dig +short TXT _acme-challenge.$DOMAIN"
    echo -e "    (you should see BOTH values) вҖ” DNS can take a few mins to propagate, be patient${R}\n"
    if certbot certonly --manual --preferred-challenges dns \
         -d "$DOMAIN" -d "*.$DOMAIN" \
         --agree-tos --register-unsafely-without-email; then
      CERT_PATH="/etc/letsencrypt/live/$DOMAIN/fullchain.pem"
      KEY_PATH="/etc/letsencrypt/live/$DOMAIN/privkey.pem"
      ok "wildcard cert issued for *.$DOMAIN рҹ”Ҙ"
    else
      warn "certbot failed вҖ” falling back to self-signed so the install can finish"
      SSL_MODE=2
    fi
    ;;
esac
if [[ "$SSL_MODE" == "2" ]]; then
  openssl req -x509 -newkey rsa:2048 -sha256 -days 3650 -nodes \
    -keyout "$CERT_DIR/key.pem" -out "$CERT_DIR/cert.pem" \
    -subj "/CN=*.$DOMAIN" \
    -addext "subjectAltName=DNS:$DOMAIN,DNS:*.$DOMAIN" >/dev/null 2>&1
  CERT_PATH="$CERT_DIR/cert.pem"; KEY_PATH="$CERT_DIR/key.pem"
  ok "self-signed wildcard cert generated"
  warn "players MUST install $CERT_DIR/cert.pem as a Trusted Root cert on their PC or osu! will refuse to connect"
fi
if [[ "$SSL_MODE" == "3" ]]; then
  ask "path to your fullchain cert" "";  CERT_PATH="$REPLY_VAL"
  ask "path to your private key" "";     KEY_PATH="$REPLY_VAL"
  [[ -f "$CERT_PATH" && -f "$KEY_PATH" ]] || warn "those files don't exist yet вҖ” nginx will fail to start until they do"
fi

