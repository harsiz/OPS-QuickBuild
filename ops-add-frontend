#!/usr/bin/env bash
#
#  OPS_QuickBuild — add-on: web frontend (guweb) + avatar routing fix 🌐😎
#
#  Bolts a website onto an EXISTING OPS_QuickBuild install:
#    • guweb (the standard bancho.py frontend: profiles, leaderboards,
#      settings w/ avatar upload, admin panel) on your apex domain
#    • fixes nginx so a.<domain> serves avatars from disk (the official way)
#    • touches NOTHING that already works — reads your existing .env,
#      no questions you already answered
#
#  usage:  sudo ./ops-add-frontend [/opt/yourserver]
#
set -euo pipefail

GUWEB_REPO="https://github.com/Varkaria/guweb.git"
FRONTEND_PORT=8000  # hardcoded inside guweb's main.py

R=$'\033[0m'; B=$'\033[1m'; DIM=$'\033[2m'
RED=$'\033[31m'; GRN=$'\033[32m'; YLW=$'\033[33m'; CYN=$'\033[36m'; MAG=$'\033[35m'; PNK=$'\033[95m'

ok()   { echo -e "  ${GRN}✅ $*${R}"; }
info() { echo -e "  ${CYN}🔹 $*${R}"; }
warn() { echo -e "  ${YLW}⚠️  $*${R}"; }
die()  { echo -e "\n  ${RED}${B}💀 nah that ain't it: $*${R}\n" >&2; exit 1; }
step() { STEP_N=$((STEP_N+1)); echo -e "\n${MAG}${B}── [$STEP_N/$STEP_TOTAL] $* ──${R}"; }
STEP_N=0; STEP_TOTAL=6

echo -e "${PNK}${B}\n   🌐 OPS_QuickBuild — frontend add-on (guweb) 😎\n${R}"

[[ "$(id -u)" -eq 0 ]] || die "run me as root (sudo ./ops-add-frontend)"

# ─── locate the existing install ─────────────────────────────────────────────
INSTALL_DIR="${1-}"
if [[ -z "$INSTALL_DIR" ]]; then
  for d in /opt/*/bancho.py/.env; do
    [[ -f "$d" ]] && INSTALL_DIR="$(dirname "$(dirname "$d")")" && break
  done
fi
[[ -n "$INSTALL_DIR" && -f "$INSTALL_DIR/bancho.py/.env" ]] \
  || die "couldn't find an OPS install — pass it explicitly: sudo ./ops-add-frontend /opt/yourserver"

BANCHO_DIR="$INSTALL_DIR/bancho.py"
SLUG="$(basename "$INSTALL_DIR")"
info "found your server at ${B}$INSTALL_DIR${R} — reusing everything it already set up"

# pull what we need from the existing .env (no re-asking 🤝)
env_get() { grep -E "^$1=" "$BANCHO_DIR/.env" | head -1 | cut -d= -f2-; }
DOMAIN="$(env_get DOMAIN)"
DB_NAME="$(env_get DB_NAME)"
DB_USER="$(env_get DB_USER)"
DB_PASS="$(env_get DB_PASS)"
APP_PORT="$(env_get APP_PORT)"
DATA_DIR="$(env_get DATA_DIRECTORY)"
CERT_PATH="$(env_get SSL_CERT_PATH)"
KEY_PATH="$(env_get SSL_KEY_PATH)"
[[ -n "$DOMAIN" && -n "$DB_PASS" ]] || die "your .env is missing DOMAIN/DB creds?? that's cursed, check $BANCHO_DIR/.env"
ok "config loaded: domain=$DOMAIN db=$DB_NAME"

command -v uv >/dev/null 2>&1 || export PATH="$HOME/.local/bin:$HOME/.cargo/bin:$PATH"
command -v uv >/dev/null 2>&1 || die "uv not found — run the main ops-quickbuild first"

# ─── 1. avatars dir + default pfp ────────────────────────────────────────────
step "🖼️  setting up avatar storage"
mkdir -p "$DATA_DIR/avatars" "$DATA_DIR/assets"
if [[ ! -f "$DATA_DIR/avatars/default.jpg" ]]; then
  curl -fsSL -o "$DATA_DIR/avatars/default.jpg" "https://a.ppy.sh/" 2>/dev/null \
    && ok "default avatar downloaded" \
    || warn "couldn't grab a default avatar — drop any image at $DATA_DIR/avatars/default.jpg"
else
  ok "avatar dir already good"
fi

# ─── 2. clone guweb ──────────────────────────────────────────────────────────
step "⬇️  pulling guweb (profiles, leaderboards, settings, admin panel)"
GUWEB_DIR="$INSTALL_DIR/guweb"
if [[ -d "$GUWEB_DIR/.git" ]]; then
  warn "guweb already cloned — reusing it"
else
  git clone --depth 1 "$GUWEB_REPO" "$GUWEB_DIR" 2>&1 | tail -1
fi
ok "guweb source in place"

# ─── 3. python env (guweb is older code, it gets python 3.11) ────────────────
step "🐍 building guweb's python env"
cd "$GUWEB_DIR"
[[ -d .venv ]] || uv venv --python 3.11 .venv >/dev/null 2>&1
uv pip install --python .venv/bin/python -r requirements.txt >/dev/null
ok "guweb deps installed (own venv, doesn't touch bancho.py's)"

# ─── 4. guweb config ─────────────────────────────────────────────────────────
step "⚙️  writing guweb config"
if [[ -f "$GUWEB_DIR/config.py" ]]; then
  warn "config.py already exists — keeping yours"
else
  SECRET="$(openssl rand -hex 24)"
  cat > "$GUWEB_DIR/config.py" <<PY
# generated by OPS_QuickBuild (frontend add-on)
app_name = '$SLUG'
secret_key = '$SECRET'

# get free keys at https://www.hcaptcha.com/ if you want web signups w/ captcha
hCaptcha_sitekey = 'changeme'
hCaptcha_secret = 'changeme'

domain = '$DOMAIN'
max_image_size = 2  # MB, avatar upload limit

mysql = {
    'db': '$DB_NAME',
    'host': 'localhost',
    'user': '$DB_USER',
    'password': '$DB_PASS',
}

path_to_gulag = '$BANCHO_DIR/'

debug = False
disallowed_names = {'cookiezi', 'rrtyui'}
disallowed_passwords = {'password', 'abc123'}
registration = True

github = ''
discord_server = ''
youtube = ''
twitter = ''
instagram = ''
PY
  ok "config.py written (db creds + paths wired from your install)"
fi

# ─── 5. nginx — frontend on apex, avatars from disk ──────────────────────────
step "🌐 rewriting nginx (apex → website, a.$DOMAIN → avatars, game routes untouched)"
DOMAIN_ESC="${DOMAIN//./\\.}"
cat > "/etc/nginx/sites-available/$SLUG.conf" <<NGINX
# generated by OPS_QuickBuild (frontend add-on) for $SLUG
upstream ${SLUG}_bancho {
    server 127.0.0.1:$APP_PORT;
}
upstream ${SLUG}_web {
    server 127.0.0.1:$FRONTEND_PORT;
}

server {
    listen 80;
    server_name $DOMAIN *.$DOMAIN;
    return 301 https://\$host\$request_uri;
}

# osu! game traffic → bancho.py
server {
    listen 443 ssl;
    server_name ~^(?:osu|b|api|c[e4-6]?)\.$DOMAIN_ESC\$;

    ssl_certificate     $CERT_PATH;
    ssl_certificate_key $KEY_PATH;

    client_max_body_size 64m;

    location / {
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header Host \$http_host;
        proxy_redirect off;
        proxy_pass http://${SLUG}_bancho;
    }
}

# website (guweb) on the apex domain
server {
    listen 443 ssl;
    server_name $DOMAIN www.$DOMAIN;

    ssl_certificate     $CERT_PATH;
    ssl_certificate_key $KEY_PATH;

    client_max_body_size 8m;

    location / {
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header Host \$http_host;
        proxy_redirect off;
        proxy_pass http://${SLUG}_web;
    }
}

# avatars — served straight from disk (drop {user_id}.png/jpg in there)
server {
    listen 443 ssl;
    server_name a.$DOMAIN;

    ssl_certificate     $CERT_PATH;
    ssl_certificate_key $KEY_PATH;

    location / {
        root $DATA_DIR/avatars;
        try_files \$uri \$uri.png \$uri.jpg \$uri.gif \$uri.jpeg \$uri.jfif /default.jpg;
    }
}

# static assets (achievement icons etc.)
server {
    listen 443 ssl;
    server_name assets.$DOMAIN;

    ssl_certificate     $CERT_PATH;
    ssl_certificate_key $KEY_PATH;

    location / {
        default_type image/png;
        root $DATA_DIR/assets;
    }
}
NGINX
ln -sf "/etc/nginx/sites-available/$SLUG.conf" "/etc/nginx/sites-enabled/$SLUG.conf"
nginx -t >/dev/null 2>&1 || die "nginx config test failed — run 'nginx -t' to see why (certs?)"
systemctl reload nginx
ok "nginx reloaded — avatar routing is now correct too (it was proxied wrong before, fixed 🩹)"

# ─── 6. start script ─────────────────────────────────────────────────────────
step "🚀 start script + final word"
cat > "$INSTALL_DIR/start_frontend.sh" <<SH
#!/usr/bin/env bash
# start the $SLUG website — run me inside tmux/screen
cd "$GUWEB_DIR"
exec "$GUWEB_DIR/.venv/bin/python" main.py
SH
chmod +x "$INSTALL_DIR/start_frontend.sh"
ok "start_frontend.sh ready"

echo -e "\n${GRN}${B}  ═════════════════════════════════════════════════${R}"
echo -e "  ${GRN}${B}🎉 FRONTEND'S IN. your server has a face now 😎${R}"
echo -e "${GRN}${B}  ═════════════════════════════════════════════════${R}\n"
echo -e "  ${B}${PNK}🚀 start the website (separate tmux from the game server):${R}"
echo -e "     ${GRN}${B}tmux new -s $SLUG-web $INSTALL_DIR/start_frontend.sh${R}\n"
echo -e "  ${B}${PNK}🌐 then it's live at:${R} ${B}https://$DOMAIN${R}"
echo -e "     ${DIM}profiles • leaderboards • settings (incl. avatar upload) • /admin panel${R}\n"
echo -e "  ${B}${PNK}🖼️  profile pictures:${R}"
echo -e "     • players: log in on the site → settings → upload avatar"
echo -e "     • manual: drop ${B}{user_id}.png${R} (or .jpg) into ${B}$DATA_DIR/avatars/${R} — instant, no restart"
echo -e "     ${DIM}(user ids: check the profile url on the site, or leaderboard.sh)${R}\n"
echo -e "  ${DIM}note: guweb is the community-standard frontend but it's older code — if a page"
echo -e "  errors on a fresh bancho.py schema, it's cosmetic, the game server is unaffected.${R}"
echo -e "  ${DIM}web signups are ON (registration=True in $GUWEB_DIR/config.py); for captcha,"
echo -e "  add real hCaptcha keys in that file. game server does NOT need a restart 🫡${R}\n"
